{
    "compilerOptions": {
        "outDir": "./build/",
        "noImplicitAny": true,
        "module": "es6",
        "target": "ES2016",
        "allowJs": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "noEmit": false,
        "noEmitOnError": false,
        "lib": ["ES2016", "DOM"]
    },
    "include": ["src/**/*", "node_modules/melvor-types", "../Custom-Modifiers-in-Melvor/_definitions/**/*"]
}
